# ── API ──────────────────────────────────────
# Backend API URL (includes /api prefix in requests)
VITE_API_URL=https://sta.cdhc.vn

# ── Authentication ────────────────────────────
# Google OAuth Client ID
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Telegram Bot Username (optional — for Telegram login widget)
# VITE_TELEGRAM_BOT_USERNAME=your_telegram_bot

# ── Web3 ──────────────────────────────────────
# WalletConnect Project ID (optional — for WalletConnect modal)
# Register at: https://cloud.reown.com
# VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
